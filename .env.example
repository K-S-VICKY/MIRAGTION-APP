# Required Document360 API configuration
REACT_APP_API_URL=https://apihub.document360.io/v2/articles
REACT_APP_API_KEY=YOUR_API_KEY_HERE

# Optional payload fields
REACT_APP_USER_ID=YOUR_USER_ID_HERE
REACT_APP_CATEGORY_ID=
REACT_APP_PROJECT_VERSION_ID=
REACT_APP_LANGUAGE_CODE=

# Optional auth header customization
# Default header is "api_token" and no prefix (raw token).
REACT_APP_DOC360_API_TOKEN_HEADER=api_token
REACT_APP_DOC360_API_TOKEN_PREFIX=
